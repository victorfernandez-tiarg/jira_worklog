# ─────────────────────────────────────────────
# Opción A: API Token (recomendado para empezar)
# ─────────────────────────────────────────────
JIRA_BASE_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=tu_api_token_aqui

# ─────────────────────────────────────────────
# Opción B: OAuth 2.0 (3-legged)
# Registrar app en: https://developer.atlassian.com/console/myapps/
# ─────────────────────────────────────────────
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
SESSION_SECRET=cambia_esto_por_un_string_aleatorio_largo
AUTH_MODE=token
# AUTH_MODE=oauth
